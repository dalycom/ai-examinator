# Shared (docker-compose)
POSTGRES_USER=ai_examinator
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=ai_examinator

# Runtime: least-privilege app role (RLS enforced). Migrations use superuser URL.
DATABASE_URL=postgresql+psycopg://ai_examinator_app:change_me_in_local_env@postgres:5432/ai_examinator
MIGRATION_DATABASE_URL=postgresql+psycopg://ai_examinator:change_me_in_local_env@postgres:5432/ai_examinator

# Local host access (Postgres mapped to 5433 on host)
# DATABASE_URL=postgresql+psycopg://ai_examinator_app:change_me_in_local_env@localhost:5433/ai_examinator
# MIGRATION_DATABASE_URL=postgresql+psycopg://ai_examinator:change_me_in_local_env@localhost:5433/ai_examinator

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=ai-examinator
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin

APP_ENV=local
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

AI_ALLOW_EXTERNAL_PHI=false
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar,fr

# LLM — default stub for local dev; use preset for Meditron/BioMistral
LLM_PROVIDER=stub
LLM_MODEL_ID=stub-clinical-v1
# LLM_PROVIDER=local
# LLM_MODEL_PRESET=meditron-7b
# LLM_MODEL_PRESET=biomistral-7b
# LLM_ENDPOINT_URL=http://host.docker.internal:11434
# LLM_TIMEOUT_SECONDS=180
# LLM_PROMPT_VERSION=extraction-v2-meditron

NEXT_PUBLIC_API_URL=http://localhost:8000
